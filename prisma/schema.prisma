generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String     @id @default(cuid())
  name                 String?
  email                String?    @unique
  phoneNumber          String?
  passwordHash         String?
  role                 Role       @default(TENANT)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  calendarType         String     @default("GREGORIAN")
  auditLogs            AuditLog[]
  leases               Lease[]    @relation("TenantLeases")
  approvedPayments     Payment[]  @relation("AccountantApprovals")
  payments             Payment[]  @relation("TenantPayments")
  penalties            Penalty[]  @relation("TenantPenalties")
  refunds              Refund[]   @relation("TenantRefunds")
  approvedRefunds      Refund[]   @relation("ManagerApprovals")
  accountantProperties Property[] @relation("PropertyAccountant")
  managedProperties    Property[] @relation("PropertyManager")
}

model Property {
  id           String       @id @default(cuid())
  name         String
  address      String
  type         PropertyType @default(RESIDENTIAL)
  managerId    String
  accountantId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  accountant   User?        @relation("PropertyAccountant", fields: [accountantId], references: [id])
  manager      User         @relation("PropertyManager", fields: [managerId], references: [id])
  units        Unit[]
}

model Unit {
  id         String     @id @default(cuid())
  propertyId String
  unitNumber String
  type       String
  rentAmount Float
  status     UnitStatus @default(AVAILABLE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  floor      Int?
  size       Float?
  qrSlug     String?    @unique
  qrPrinted  Boolean    @default(false)
  leases     Lease[]
  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, unitNumber])
}

model Lease {
  id                String      @id @default(cuid())
  unitId            String
  tenantId          String
  startDate         DateTime
  endDate           DateTime
  status            LeaseStatus @default(PENDING)
  terms             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  leaseAgreementUrl String?
  advanceBalance    Float       @default(0)
  tenant            User        @relation("TenantLeases", fields: [tenantId], references: [id])
  unit              Unit        @relation(fields: [unitId], references: [id])
  payments          Payment[]
  penalties         Penalty[]
  refunds           Refund[]
}

model Payment {
  id            String        @id @default(cuid())
  tenantId      String
  leaseId       String
  amount        Float
  dueDate       DateTime
  paidAt        DateTime?
  status        PaymentStatus @default(PENDING)
  type          PaymentType   @default(MONTHLY)
  advanceUntil  DateTime?
  approvedBy    String?
  approver      User?         @relation("AccountantApprovals", fields: [approvedBy], references: [id])
  receiptUrl    String?
  senderName    String?
  transactionId String?
  penalty       Float?        @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lease         Lease         @relation(fields: [leaseId], references: [id])
  tenant        User          @relation("TenantPayments", fields: [tenantId], references: [id])
}

model Penalty {
  id            String    @id @default(cuid())
  leaseId       String
  tenantId      String
  amount        Float
  paidAmount    Float     @default(0)
  status        String    @default("UNPAID") // UNPAID, PARTIAL, PAID
  dueDate       DateTime
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lease         Lease     @relation(fields: [leaseId], references: [id])
  tenant        User      @relation("TenantPenalties", fields: [tenantId], references: [id])
}

model Refund {
  id            String        @id @default(cuid())
  tenantId      String
  leaseId       String
  amount        Float
  reason        String?
  status        RefundStatus  @default(PENDING)
  approvedBy    String?
  approver      User?         @relation("ManagerApprovals", fields: [approvedBy], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lease         Lease         @relation(fields: [leaseId], references: [id])
  tenant        User          @relation("TenantRefunds", fields: [tenantId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  actionType String   @default("UNKNOWN")
  oldValue   String?
  newValue   String?
  metadata   String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model SystemSettings {
  id                String   @id @default("global")
  systemName        String   @default("NexusPMS")
  organizationName  String?
  tinNumber         String?
  address           String?
  website           String?
  phone             String?
  logoUrl           String?
  primaryColor      String   @default("#2563eb")
  supportEmail      String?
  currency          String   @default("USD")
  calendarType      String   @default("GREGORIAN")
  lateFeeEnabled       Boolean  @default(false)
  lateFeePercentage    Float    @default(5.0)
  warningFeePercentage Float    @default(10.0)
  smtpHost             String?
  smtpPort          Int?
  smtpUser          String?
  smtpPass          String?
  ftpHost           String?
  ftpPort           Int?
  ftpUser           String?
  ftpPass           String?
  ftpEnabled        Boolean  @default(false)
  ftpBaseUrl        String?
  smsEthiopiaKey    String?
  smsEnabled        Boolean  @default(true)
  maintenanceMode   Boolean  @default(false)
  maintenanceMessage String? @default("We are currently performing scheduled maintenance. Please check back shortly.")
  qrBackupEmail     String?
  verifyEtApiKey     String?
  verifyEtWebhookSecret String?
  verifyEtEnabled    Boolean  @default(false)
  updatedAt         DateTime @updatedAt
}

model SmsLog {
  id        String   @id @default(cuid())
  msisdn    String
  message   String
  status    String   @default("PENDING")
  source    String?
  response  String?
  createdAt DateTime @default(now())
}

model BankAccount {
  id            String   @id @default(cuid())
  bankName      String
  accountName   String
  accountNumber String
  createdAt     DateTime @default(now())
}

model SmsTemplate {
  id          String   @id @default(cuid())
  name        String
  slug        String?  @unique
  enabled     Boolean  @default(true)
  description String?
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Otp {
  id         String   @id @default(cuid())
  identifier String
  code       String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

enum Role {
  ADMIN
  ACCOUNTANT
  MANAGER
  TENANT
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  BOTH
}

enum UnitStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum LeaseStatus {
  PENDING
  ACTIVE
  EXPIRED
  TERMINATED
}

enum PaymentType {
  MONTHLY
  ADVANCE
  PENALTY
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
}
